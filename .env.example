# Tavily Search API
TAVILY_API_KEY=

# Hermes config
HERMES_RUN_MODE=runs
# runs is the preferred report path. HTTP/SSE remains configured as fallback.
# Docker deployment defaults use the shared hermes-net network.
HERMES_BASE_URL=http://hermes:8642/v1
HERMES_HEALTH_URL=http://hermes:8642/health
HERMES_RUNS_URL=http://hermes:8642/v1/runs
HERMES_API_KEY=
HERMES_MODEL=hermes-agent
HERMES_QA_AGENT_ID=qa-agent
HERMES_QA_MODEL=openclaw/qa-agent
HERMES_QA_MODE=direct_pg
HERMES_QA_TIMEOUT_MS=900000
HERMES_QA_ARTIFACT_DIR=/usr/docker/hermes/workspace/qa-agent/sessions

# Remote SSH config. Leave empty for local development.
HERMES_REMOTE_HOST=
HERMES_REMOTE_USER=root
HERMES_REMOTE_SSH_KEY=~/.ssh/id_ed25519
HERMES_REMOTE_REPORT_DIR=/opt/hermes/workspace/report-agent/reports
HERMES_REMOTE_CONTAINER_REPORT_DIR=/opt/data/workspace/report-agent/reports
HERMES_CONTAINER_REPORT_DIR=/opt/data/workspace/report-agent/reports
# Unified report artifact storage. Frontend only reads artifacts through NestJS APIs.
# local: Nest copies final reports into ARTIFACT_LOCAL_ROOT, which must be a persistent Docker volume.
# s3: reserved for S3/MinIO/OSS-compatible storage.
ARTIFACT_STORAGE_MODE=local
ARTIFACT_LOCAL_ROOT=/app/storage/artifacts
# Stage A keeps /opt/hermes:/opt/data for compatibility. Set false only after Stage B audit passes.
HERMES_API_LEGACY_DATA_MOUNT=true
# Stage B can mount /opt/hermes/workspace/report-agent/config directly here instead of broad /opt/data.
HERMES_RESEARCH_KEYS_DIR=/opt/data/workspace/report-agent/config
# Legacy report writers should resolve to the API-managed artifact volume, not the Hermes inbox.
REPORT_OUTPUT_DIR=/app/storage/artifacts
# Shared-volume transport from Hermes to Nest. Hermes returns paths under HERMES_REMOTE_REPORT_ROOT;
# Nest reads the same mounted volume from HERMES_SHARED_REPORT_ROOT, then stores a normalized artifact.
HERMES_ARTIFACT_TRANSPORT=shared_volume
HERMES_REMOTE_REPORT_ROOT=/opt/data/workspace/report-agent/reports
HERMES_SHARED_REPORT_ROOT=/app/hermes-inbox
# Optional legacy artifact path mapping for shared-volume deployments.
# Hermes may return paths under HERMES_REMOTE_OUTPUT_DIR while Nest reads the same volume at HERMES_LOCAL_OUTPUT_DIR.
HERMES_REMOTE_OUTPUT_DIR=/opt/data/workspace/report-agent/reports
HERMES_LOCAL_OUTPUT_DIR=/app/storage/artifacts
# Optional for truly remote Hermes deployments without shared storage.
HERMES_ARTIFACT_BASE_URL=
HERMES_INTERNAL_TOKEN=
# Future S3/MinIO/OSS-compatible artifact storage.
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_FORCE_PATH_STYLE=true
S3_ARTIFACT_PREFIX=hermes-artifacts
HERMES_REMOTE_CLI_CONTAINER=hermes
HERMES_REMOTE_CLI_BINARY=/opt/hermes/.venv/bin/hermes
HERMES_REMOTE_CLI_HOME=/opt/data
# Optional overrides when Hermes config.yaml should not provide the default.
HERMES_REMOTE_CLI_PROVIDER=
HERMES_REMOTE_CLI_MODEL=

# Report execution provider.
# hermes: keep using Hermes Gateway/CLI.
# codex/openai_compatible/claude_api: use an OpenAI-compatible chat completions API.
# cli/codex_cli/claude_cli: pipe the prepared report prompt to a local CLI command.
REPORT_AGENT_PROVIDER=hermes
REPORT_AGENT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
REPORT_AGENT_API_KEY=
REPORT_AGENT_MODEL=deepseek-v4-flash
REPORT_AGENT_CLI_COMMAND=
REPORT_AGENT_CLI_ARGS_JSON=[]

# Optional: PostgreSQL pgvector semantic source recall.
# Example: postgres://user:password@host:5432/news
PGVECTOR_DATABASE_URL=
PGVECTOR_NEWS_TABLE=news
PGVECTOR_INDEX_TABLE=news_vector_chunks
PGVECTOR_EMBEDDING_MODEL=text-embedding-3-small

# Optional: dedicated PostgreSQL database for login, users, and chat ownership metadata.
# If empty, the backend falls back to PGVECTOR_DATABASE_URL for backward compatibility.
# Example: postgres://user:password@host:5432/hermes_auth
AUTH_DATABASE_URL=

# JWT signing key for auth tokens. Required in deployment.
JWT_SECRET=

# Daily Awareness V2 internal event and recoverable Inbox worker.
# Use a dedicated random secret; this is independent from user JWT authentication.
DAILY_AWARENESS_INTERNAL_EVENT_KEY=
DAILY_AWARENESS_WORKER_POLL_MS=2000
DAILY_AWARENESS_INBOX_LEASE_SECONDS=300
DAILY_AWARENESS_INBOX_MAX_ATTEMPTS=5
DAILY_AWARENESS_INBOX_RETRY_SECONDS=30

# Optional: DashScope text-embedding-v4 service, OpenAI-compatible /v1/embeddings.
# Keep each embedding model in a separate table; do not mix vector spaces.
# PGVECTOR_NEWS_TABLE=vector_materials_text_embedding_v4
# PGVECTOR_EMBEDDING_MODEL=text-embedding-v4
# PGVECTOR_EMBEDDING_DIMENSIONS=1024
# PGVECTOR_EMBEDDING_INPUT_CHARS=600
# PGVECTOR_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Deployment config used by deploy.sh.
REMOTE_HOST=
REMOTE_USER=root
SSH_KEY=~/.ssh/id_ed25519
# Required deployment-only secret. It is hashed locally and is never written to the container env file.
BOOTSTRAP_ADMIN_PASSWORD=
# Set true for an intentional administrator password rotation, then return it to false.
ROTATE_BOOTSTRAP_ADMIN_PASSWORD=false
