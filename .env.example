# Tavily Search API
TAVILY_API_KEY=

# Hermes config
HERMES_RUN_MODE=runs
# runs is the preferred report path. HTTP/SSE remains configured as fallback.
# Docker deployment defaults use the shared hermes-net network.
HERMES_BASE_URL=http://hermes:8642/v1
HERMES_HEALTH_URL=http://hermes:8642/health
HERMES_RUNS_URL=http://hermes:8642/v1/runs
HERMES_API_KEY=
HERMES_MODEL=hermes-agent
HERMES_QA_AGENT_ID=qa-agent
HERMES_QA_MODEL=openclaw/qa-agent
HERMES_QA_MODE=direct_pg
HERMES_QA_TIMEOUT_MS=900000
HERMES_QA_ARTIFACT_DIR=/usr/docker/hermes/workspace/qa-agent/sessions

# Remote SSH config. Leave empty for local development.
HERMES_REMOTE_HOST=
HERMES_REMOTE_USER=root
HERMES_REMOTE_SSH_KEY=~/.ssh/id_ed25519
HERMES_REMOTE_REPORT_DIR=/opt/hermes/workspace/report-agent/reports
HERMES_REMOTE_CONTAINER_REPORT_DIR=/opt/data/workspace/report-agent/reports
HERMES_CONTAINER_REPORT_DIR=/opt/data/workspace/report-agent/reports
HERMES_REMOTE_CLI_CONTAINER=hermes
HERMES_REMOTE_CLI_BINARY=/opt/hermes/.venv/bin/hermes
HERMES_REMOTE_CLI_HOME=/opt/data
# Optional overrides when Hermes config.yaml should not provide the default.
HERMES_REMOTE_CLI_PROVIDER=
HERMES_REMOTE_CLI_MODEL=

# Report execution provider.
# hermes: keep using Hermes Gateway/CLI.
# codex/openai_compatible/claude_api: use an OpenAI-compatible chat completions API.
# cli/codex_cli/claude_cli: pipe the prepared report prompt to a local CLI command.
REPORT_AGENT_PROVIDER=hermes
REPORT_AGENT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
REPORT_AGENT_API_KEY=
REPORT_AGENT_MODEL=deepseek-v4-flash
REPORT_AGENT_CLI_COMMAND=
REPORT_AGENT_CLI_ARGS_JSON=[]

# Optional: PostgreSQL pgvector semantic source recall.
# Example: postgres://user:password@host:5432/news
PGVECTOR_DATABASE_URL=
PGVECTOR_NEWS_TABLE=news
PGVECTOR_INDEX_TABLE=news_vector_chunks
PGVECTOR_EMBEDDING_MODEL=text-embedding-3-small

# Optional: DashScope text-embedding-v4 service, OpenAI-compatible /v1/embeddings.
# Keep each embedding model in a separate table; do not mix vector spaces.
# PGVECTOR_NEWS_TABLE=vector_materials_text_embedding_v4
# PGVECTOR_EMBEDDING_MODEL=text-embedding-v4
# PGVECTOR_EMBEDDING_DIMENSIONS=1024
# PGVECTOR_EMBEDDING_INPUT_CHARS=600
# PGVECTOR_EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Deployment config used by deploy.sh.
REMOTE_HOST=
REMOTE_USER=root
SSH_KEY=~/.ssh/id_ed25519
